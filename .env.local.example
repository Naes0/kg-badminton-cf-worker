# Copy to .env.local and fill in values.
# register-commands script loads from .env.local
# For wrangler dev: copy to .dev.vars (wrangler loads .dev.vars for local secrets)
#
# Worker secrets (production: wrangler secret put <KEY>)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_PUBLIC_KEY=your_app_public_key_hex
#
# For register-commands script only
DISCORD_APPLICATION_ID=your_application_id
DISCORD_TOKEN=your_bot_token
